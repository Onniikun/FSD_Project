{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "strict": true,
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true

  },
    "include": ["src/**/*", "tests/**/*", "generated"],
    "exclude": ["node_modules", "dist"]
}
