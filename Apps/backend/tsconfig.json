{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "outDir": "./dist",
    "baseUrl": "./",
    "sourceMap": true,
    "lib": ["ESNext"],
    "paths": {
      "*": ["*"],
      "@shared/*": ["../../shared/*"]
    },
    "ignoreDeprecations": "6.0",
    "rootDir": "../../"
  },
  "include": [
    "src/**/*",
    "api/index.ts",
    "../../shared/types/**/*"
  ],
  "exclude": ["node_modules", "dist", "generated"]
}