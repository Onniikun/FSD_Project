{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": "../../",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*",
    "lib/**/*",
    "config/**/*",
    "../../shared/**/*"
, "shared/types"  ],
  "exclude": ["node_modules", "dist", "generated"]
}