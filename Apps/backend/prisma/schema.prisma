// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Song Item model
model SongItem {
  id           Int          @id @default(autoincrement())
  title        String
  releaseDate  DateTime?
  runtime      String?
  cover        String?
 
  links        Link[]
  artists      SongArtist[]
  genres       SongGenre[]
}
 
// Song Item Platform (one-to-many)
model Link {
  id         Int      @id @default(autoincrement())
  songItemId Int
  platform   String
  url        String
 
  songItem   SongItem @relation(fields: [songItemId], references: [id])
}
 
// Pivot: Song <-> Artist (many-to-many)
model SongArtist {
  songItemId Int
  artistId   Int
 
  songItem   SongItem @relation(fields: [songItemId], references: [id])
  artist     Artist   @relation(fields: [artistId], references: [id])
 
  @@id([songItemId, artistId])
}
 
model Artist {
  id        Int          @id @default(autoincrement())
  name      String       @unique
 
  songs     SongArtist[]
}
 
model Genre {
  id        Int          @id @default(autoincrement())
  name      String       @unique
 
  songs     SongGenre[]
}
 
// Pivot: Song <-> Genre (many-to-many)
model SongGenre {
  songItemId Int
  genreId    Int
 
  songItem   SongItem @relation(fields: [songItemId], references: [id])
  genre      Genre    @relation(fields: [genreId], references: [id])
 
  @@id([songItemId, genreId])
}


