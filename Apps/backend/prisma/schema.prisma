generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Songlist {
  id          String   @id @default(uuid())
  name        String
  visibility  String
  description String?
  cover       String?
  // Relations
  // songs SongCollection[]
}

