// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String        @id
  songlists Songlist[]
}

model Songlist {
  id          String   @id @default(uuid())
  name        String
  visibility  String
  description String?
  cover       String?

  // Ownership
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String

  // Relations
  songs SongCollection[]
}

model SongCollection {
  id         Int       @id @default(autoincrement())
  songId     Int
  songlistId String
  
  createdAt  DateTime  @default(now())

  // Relations
  song       SongItem       @relation(fields: [songId], references: [id])
  songlist   Songlist   @relation(fields: [songlistId], references: [id])
  
  // prevents duplicate entries
  @@unique([songId, songlistId]) 
}

// Song Item model
model SongItem {
  id           Int          @id @default(autoincrement())
  title        String
  releaseDate  DateTime?
  runtime      String?
  cover        String?
 
  links        Link[]
  artists      SongArtist[]
  genres       SongGenre[]
  songs        SongCollection[]
}
 
// Song Item Platform (one-to-many)
model Link {
  id         Int      @id @default(autoincrement())
  songItemId Int
  platform   String
  url        String
 
  songItem   SongItem @relation(fields: [songItemId], references: [id])
}
 
// Pivot: Song <-> Artist (many-to-many)
model SongArtist {
  songItemId Int
  artistId   Int
 
  songItem   SongItem @relation(fields: [songItemId], references: [id])
  artist     Artist   @relation(fields: [artistId], references: [id])
 
  @@id([songItemId, artistId])
}
 
model Artist {
  id        Int          @id @default(autoincrement())
  name      String       @unique
 
  songs     SongArtist[]
}
 
model Genre {
  id        Int          @id @default(autoincrement())
  name      String       @unique
 
  songs     SongGenre[]
}
 
// Pivot: Song <-> Genre (many-to-many)
model SongGenre {
  songItemId Int
  genreId    Int
 
  songItem   SongItem @relation(fields: [songItemId], references: [id])
  genre      Genre    @relation(fields: [genreId], references: [id])
 
  @@id([songItemId, genreId])
}


