generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Songlist {
  id          String           @id @default(uuid())
  name        String
  visibility  String
  description String?
  cover       String?
  songs       SongCollection[]
}

model SongCollection {
  id         Int      @id @default(autoincrement())
  songId     Int
  songlistId String
  createdAt  DateTime @default(now())
  song       SongItem @relation(fields: [songId], references: [id])
  songlist   Songlist @relation(fields: [songlistId], references: [id])

  @@unique([songId, songlistId])
}

model SongItem {
  id          Int              @id @default(autoincrement())
  title       String
  releaseDate DateTime?
  runtime     String?
  cover       String?
  links       Link[]
  artists     SongArtist[]
  songs       SongCollection[]
  genres      SongGenre[]
}

model Link {
  id         Int      @id @default(autoincrement())
  songItemId Int
  platform   String
  url        String
  songItem   SongItem @relation(fields: [songItemId], references: [id])
}

model SongArtist {
  songItemId Int
  artistId   Int
  artist     Artist   @relation(fields: [artistId], references: [id])
  songItem   SongItem @relation(fields: [songItemId], references: [id])

  @@id([songItemId, artistId])
}

model Artist {
  id    Int          @id @default(autoincrement())
  name  String       @unique
  songs SongArtist[]
}

model Genre {
  id    Int         @id @default(autoincrement())
  name  String      @unique
  songs SongGenre[]
}

model SongGenre {
  songItemId Int
  genreId    Int
  genre      Genre    @relation(fields: [genreId], references: [id])
  songItem   SongItem @relation(fields: [songItemId], references: [id])

  @@id([songItemId, genreId])
}
